<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<title>{{ fixture_name }} — registry review preview</title>
<style>
  :root {
    --ok: #2d7a2d; --partial: #b56a00; --miss: #a11; --muted: #666;
    --bg: #fafafa; --border: #ddd; --accent: #1f6feb;
  }
  * { box-sizing: border-box; }
  body { font: 14px/1.45 -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
         margin: 0; background: var(--bg); color: #222; }
  header { background: #fff; border-bottom: 1px solid var(--border); padding: 1rem 1.5rem; }
  header h1 { margin: 0 0 .25rem 0; font-size: 1.25rem; }
  header .meta { color: var(--muted); font-size: .85rem; }
  .stats { display: flex; gap: 2rem; padding: 1rem 1.5rem; background: #fff;
           border-bottom: 1px solid var(--border); }
  .stat { display: flex; flex-direction: column; }
  .stat .val { font-size: 1.5rem; font-weight: 600; }
  .stat .lbl { font-size: .75rem; color: var(--muted); text-transform: uppercase; }
  main { max-width: 1200px; margin: 0 auto; padding: 1.5rem; }
  .req { background: #fff; border: 1px solid var(--border); border-radius: 6px;
         margin-bottom: 1rem; overflow: hidden; }
  .req-head { padding: .75rem 1rem; display: flex; align-items: center; gap: .75rem;
              cursor: pointer; user-select: none; }
  .req-head:hover { background: #f3f3f3; }
  .status { font-size: .7rem; text-transform: uppercase; padding: .15rem .5rem;
            border-radius: 3px; color: #fff; font-weight: 600; }
  .status.covered { background: var(--ok); }
  .status.partial { background: var(--partial); }
  .status.missing, .status.flagged { background: var(--miss); }
  .status.suggested { background: #888; }
  .req-id { font-family: ui-monospace, Menlo, Consolas, monospace;
            font-size: .8rem; color: var(--muted); }
  .req-text { flex: 1; }
  .conf { font-family: ui-monospace, Menlo, Consolas, monospace;
          font-size: .8rem; color: var(--muted); }
  .req-body { display: none; padding: .5rem 1rem 1rem 1rem;
              border-top: 1px solid var(--border); }
  .req.open .req-body { display: block; }
  .snippet { margin-top: .5rem; padding: .75rem; background: #f8f8f8;
             border-left: 3px solid var(--accent); font-size: .9rem; }
  .snippet-meta { font-size: .75rem; color: var(--muted); margin-top: .35rem; }
  .snippet-meta .tag { display: inline-block; margin-right: .5rem; padding: .05rem .35rem;
                       border-radius: 3px; background: #eaeaea; }
  .snippet-meta .tag.no-schema { background: #ffe4d1; color: #8a4400; }
  .override { margin-top: 1rem; padding-top: .75rem; border-top: 1px dashed #ccc; }
  .override label { display: inline-block; width: 7rem; font-size: .85rem; }
  .override select, .override textarea { font-size: .85rem; padding: .25rem .35rem;
                                          border: 1px solid var(--border); border-radius: 3px; }
  .override textarea { width: 100%; min-height: 3rem; font-family: inherit; margin-top: .35rem; }
  footer { max-width: 1200px; margin: 0 auto; padding: 1rem 1.5rem; color: var(--muted);
           font-size: .8rem; }
  button.export { background: var(--accent); color: #fff; border: 0; padding: .5rem 1rem;
                  border-radius: 4px; cursor: pointer; font-weight: 500; }
  button.export:hover { background: #1a5dcf; }
</style>
</head>
<body>
<header>
  <h1>{{ fixture_name }} — registry review preview</h1>
  <div class="meta">
    Model: <strong>{{ model_name }}</strong> ·
    Generated {{ run_date }} ·
    {{ n_requirements }} requirements ·
    Methodology {{ methodology_name }}
  </div>
</header>

<div class="stats">
  <div class="stat">
    <span class="val" style="color: var(--ok)">{{ covered_count }}</span>
    <span class="lbl">covered</span>
  </div>
  <div class="stat">
    <span class="val" style="color: var(--partial)">{{ partial_count }}</span>
    <span class="lbl">partial</span>
  </div>
  <div class="stat">
    <span class="val" style="color: var(--miss)">{{ missing_count }}</span>
    <span class="lbl">missing</span>
  </div>
  <div class="stat">
    <span class="val">{{ coverage_pct }}%</span>
    <span class="lbl">coverage</span>
  </div>
</div>

<main>
  {% for req in requirements %}
  <article class="req" data-req-id="{{ req.requirement_id }}">
    <header class="req-head" onclick="this.parentElement.classList.toggle('open')">
      <span class="status {{ req.status }}">{{ req.status }}</span>
      <span class="req-id">{{ req.requirement_id }}</span>
      <span class="req-text">{{ req.requirement_text }}</span>
      {% if req.confidence is not none %}
      <span class="conf">conf {{ "%.2f"|format(req.confidence) }}</span>
      {% endif %}
    </header>
    <div class="req-body">
      <div><strong>Accepted evidence:</strong> {{ req.accepted_evidence }}</div>

      {% if req.evidence_snippets %}
        {% for s in req.evidence_snippets %}
        <div class="snippet">
          <div>{{ s.text }}</div>
          <div class="snippet-meta">
            <span class="tag">{{ s.document_name }}</span>
            {% if s.page is not none %}<span class="tag">p. {{ s.page }}</span>{% endif %}
            {% if s.section %}<span class="tag">§ {{ s.section }}</span>{% endif %}
            <span class="tag">conf {{ "%.2f"|format(s.confidence) }}</span>
            {% if s.schema_match == false %}
              <span class="tag no-schema">schema_match: false</span>
            {% endif %}
          </div>
        </div>
        {% endfor %}
      {% else %}
        <p style="color: var(--muted); font-style: italic;">No evidence snippets extracted.</p>
      {% endif %}

      <div class="override">
        <label for="v-{{ req.requirement_id }}">Override verdict:</label>
        <select id="v-{{ req.requirement_id }}" class="override-verdict"
                data-req-id="{{ req.requirement_id }}" data-original="{{ req.status }}">
          <option value="">(no override)</option>
          <option value="covered">covered</option>
          <option value="partial">partial</option>
          <option value="missing">missing</option>
          <option value="flagged">flagged</option>
        </select>
        <br>
        <label for="c-{{ req.requirement_id }}">Reviewer comment:</label>
        <textarea id="c-{{ req.requirement_id }}" class="override-comment"
                  data-req-id="{{ req.requirement_id }}"
                  placeholder="Why the override, or notes for the audit trail."></textarea>
      </div>
    </div>
  </article>
  {% endfor %}
</main>

<footer>
  <button class="export" onclick="exportOverrides()">Export overrides.json</button>
  &nbsp;
  <span>Overrides are stored only in this browser until you click Export.
        Download saves a JSON file the pipeline can consume for Phase G tuning.</span>
</footer>

<script>
function exportOverrides() {
  const out = { fixture: "{{ fixture_name }}", model: "{{ model_name }}",
                exported_at: new Date().toISOString(), overrides: [] };
  document.querySelectorAll('.override-verdict').forEach(sel => {
    const verdict = sel.value.trim();
    const commentEl = document.getElementById('c-' + sel.dataset.reqId);
    const comment = commentEl ? commentEl.value.trim() : '';
    if (verdict || comment) {
      out.overrides.push({ requirement_id: sel.dataset.reqId,
                           original_status: sel.dataset.original,
                           override_verdict: verdict || null,
                           comment: comment || null });
    }
  });
  const blob = new Blob([JSON.stringify(out, null, 2)], {type: "application/json"});
  const url = URL.createObjectURL(blob);
  const a = document.createElement('a');
  a.href = url;
  a.download = "{{ fixture_name }}-overrides.json";
  a.click();
  URL.revokeObjectURL(url);
}
</script>
</body>
</html>
